{
  "name": "okf-atlas-mcp",
  "version": "0.1.0",
  "description": "MCP server for navigating OKF knowledge bundles.",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "okf",
    "knowledge-graph",
    "claude",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodcar/okf-atlas-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/rodcar/okf-atlas-mcp/issues"
  },
  "homepage": "https://github.com/rodcar/okf-atlas-mcp#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "okf-atlas-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "commander": "^14.0.2",
    "markdown-it": "^14.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
